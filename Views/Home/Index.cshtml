@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">

    <!-- CUADRO PRINCIPAL -->
    <div class="p-5 mb-5 text-center rounded-4 shadow-lg"
         style="background: linear-gradient(135deg, #ffb6c1, #ff69b4); color:white;">

        <h1 class="display-3 fw-bold mb-3">
             Tienda Virtual Valentina 
        </h1>

        <p class="lead">
            
        </p>

    </div>

    <!-- CUADROS INFERIORES -->
    <div class="row g-4">

        <!-- USUARIOS -->
        <div class="col-md-4">

            <div class="card border-0 shadow rounded-4 text-center p-4 h-100 card-hover">

                <div class="card-body">

                    <i class="bi bi-person-heart-fill text-danger"
                       style="font-size:55px;"></i>

                    <h3 class="fw-bold mt-3">
                        Usuarios
                    </h3>

                   

                 
                    <a href="/Usuario"
                       class="btn btn-outline-danger rounded-pill px-4">
                        Ingresar
                    </a>

                </div>

            </div>

        </div>

        <!-- CATEGORIAS -->
        <div class="col-md-4">

            <div class="card border-0 shadow rounded-4 text-center p-4 h-100 card-hover">

                <div class="card-body">

                    <i class="bi bi-stars text-warning"
                       style="font-size:55px;"></i>

                    <h3 class="fw-bold mt-3">
                        Categorías
                    </h3>

                   

                    <a href="/Categoria"
                       class="btn btn-outline-warning rounded-pill px-4">
                        Ingresar
                    </a>

                </div>

            </div>

        </div>

        <!-- PRODUCTOS -->
        <div class="col-md-4">

            <div class="card border-0 shadow rounded-4 text-center p-4 h-100 card-hover">

                <div class="card-body">

                    <i class="bi bi-bag-heart-fill text-primary"
                       style="font-size:55px;"></i>

                    <h3 class="fw-bold mt-3">
                        Productos
                    </h3>

                    

                    <a href="/Producto"
                       class="btn btn-outline-primary rounded-pill px-4">
                        Ingresar
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

    body {
        background-color: #fff5f8;
    }

    .card-hover {
        transition: all 0.3s ease;
    }

        .card-hover:hover {
            transform: translateY(-10px);
            box-shadow: 0px 12px 25px rgba(255, 105, 180, 0.25);
        }
</style>
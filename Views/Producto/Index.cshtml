<a class="btn btn-success" href="/Producto/Create">Nuevo Producto</a>
<br>
<br>
<table class="table table-stripes table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Categoría</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Precio</td>
                <td>@item.Stock</td>
                <td>@item.Categoria?.Nombre</td>

                <td>
                    @if (Context.Session.GetString("Rol") == "Admin")
                    {
                        <a class="btn btn-warning btn-sm" href="/Producto/Edit/@item.Id">Editar</a>
                        <a class="btn btn-danger btn-sm" href="/Producto/Delete/@item.Id">Eliminar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
@model List<TiendaVirtualValentina.Models.Producto>

<div class="container mt-4">

    <h2 class="mb-4 text-center">Productos</h2>

    <a class="btn btn-success mb-3" href="/Producto/Create">
        + Nuevo Producto
    </a>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4">

                <div class="card h-100 shadow">

                    <img src="@item.ImagenUrl"
                         class="card-img-top"
                         style="height:200px; object-fit:cover;" />

                    <div class="card-body">

                        <h5 class="card-title">@item.Nombre</h5>

                        <p class="card-text">
                            Precio: $@item.Precio <br />
                            Stock: @item.Stock <br />
                            Categoria: @item.Categoria?.Nombre
                        </p>

                        <a href="/Producto/Edit/@item.Id" class="btn btn-warning btn-sm">Editar</a>

                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline">
                            <button type="submit" class="btn btn-danger btn-sm">
                                Eliminar
                            </button>
                        </form>

                    </div>

                </div>

            </div>
        }

    </div>

</div>